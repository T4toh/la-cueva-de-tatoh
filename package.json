{
  "name": "la-cueva-de-tatoh",
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build componentes && ng build perfil-personal --configuration=production && ng build comidas --configuration=production --base-href=/comidas/ && mkdir -p dist/perfil-personal/browser/comidas && cp -r dist/comidas/browser/. dist/perfil-personal/browser/comidas/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "build:comidas": "ng build comidas --configuration=production",
    "build:comidas:android": "ng build comidas --configuration=production && npx cap sync android",
    "open:android": "npm run build:comidas:android && npx cap open android"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@angular/service-worker": "^21.2.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/status-bar": "^8.0.1",
    "firebase": "^12.10.0",
    "ngx-markdown": "^21.1.0",
    "prismjs": "^1.30.0",
    "qr-code-styling": "^1.9.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "~6.0.0",
    "angular-eslint": "21.3.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jasmine-core": "~6.1.0",
    "jsdom": "^28.1.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.18"
  }
}
